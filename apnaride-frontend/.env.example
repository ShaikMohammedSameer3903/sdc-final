# ========================================
# ApnaRide Frontend Environment Configuration
# ========================================
# Copy this file to .env and update values for your environment

# ========================================
# API Configuration
# ========================================
# Backend API URL - Change this for production deployment
# Development: http://localhost:9031/api
# Production: http://44.220.151.172:9031/api
VITE_API_BASE=http://localhost:9031/api

# WebSocket URL - Change this for production deployment
# Development: ws://localhost:9031
# Production: ws://44.220.151.172:9031
VITE_WS_BASE_URL=ws://localhost:9031

# ========================================
# Application Configuration
# ========================================
VITE_APP_NAME=ApnaRide
VITE_APP_VERSION=1.0.0

# ========================================
# Map Configuration
# ========================================
# Default map center (New Delhi, India)
VITE_MAP_DEFAULT_LAT=28.6139
VITE_MAP_DEFAULT_LNG=77.2090
VITE_MAP_DEFAULT_ZOOM=13

# ========================================
# Feature Flags
# ========================================
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=false

# ========================================
# Payment Configuration (Optional)
# ========================================
# Razorpay Key for payment integration
VITE_RAZORPAY_KEY=rzp_test_xxxxxxxxxxxx
