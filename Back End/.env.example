# ========================================
# ApnaRide Backend Environment Configuration
# ========================================
# Copy this file to .env and update values for your environment

# ========================================
# Server Configuration
# ========================================
SERVER_PORT=9031

# ========================================
# Database Configuration
# ========================================
DB_HOST=database-1.cc38e2ug2u3c.us-east-1.rds.amazonaws.com
DB_PORT=3306
DB_NAME=apnaride
DB_USERNAME=admin
DB_PASSWORD=12345678

# ========================================
# JPA/Hibernate Configuration
# ========================================
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true

# ========================================
# CORS Configuration
# ========================================
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://44.220.151.172:5173

# ========================================
# WebSocket Configuration
# ========================================
# Comma-separated list of allowed WebSocket origins
WEBSOCKET_ALLOWED_ORIGINS=http://localhost:5173,http://44.220.151.172:5173

# ========================================
# Frontend URL (for OAuth redirects)
# ========================================
FRONTEND_URL=http://44.220.151.172:5173

# ========================================
# Application Environment
# ========================================
SPRING_PROFILES_ACTIVE=dev

# ========================================
# Google OAuth2 Configuration
# ========================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ========================================
# Security Configuration
# ========================================
JWT_SECRET=your_jwt_secret_key_here_minimum_256_bits
JWT_EXPIRATION=86400000
